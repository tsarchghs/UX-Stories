
enum Platform {
  IOS
  ANDROID
}

enum AccountType {
  MEMBER
  ADMIN
}

type File {
  id: ID! @unique @id
  filename: String!
  mimetype: String!
  encoding: String!
  url: String! @unique  
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type Video {
  id: ID! @unique @id
  file: File!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type Job {
  id: ID! @unique @id
  name: String! @unique
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type User {
  id: ID! @unique @id
  email: String! @unique
  password: String!
  full_name: String!
  job: Job!
  role: AccountType!
  profile_photo: File
  customer_id: ID
  subscription_id: ID
  apps: [App!]!
  libraries: [Library!]!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type AppVersion {
  id: ID! @unique @id
  name: String! @unique 
  stories: [Story!]!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type AppCategory {
  id: ID! @unique @id
  name: String! @unique 
  stories: [Story!]!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type StoryCategory {
  id: ID! @unique @id
  name: String! @unique 
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
  stories: [Story!]!
}

type StoryElement {
  id: ID! @unique @id
  name: String! @unique 
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
  stories: [Story!]!
}

type App {
  id: ID! @unique @id
  createdBy: User!
  appCategory: AppCategory!
  appVersions: [AppVersion!]!
  stories: [Story!]!
  name: String!
  description: String
  company: String!
  logo: File!
  platform: Platform!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type Story {
  id: ID! @unique @id
  createdBy: User!
  app: App!
  appVersions: [AppVersion!]!
  storyCategories: [StoryCategory!]!
  storyElements: [StoryElement!]!
  libraries: [Library!]!
  video: Video!
  thumbnail: File!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}

type Library {
  id: ID! @unique @id
  createdBy: User!
  stories: [Story!]!
  name: String!
  custom_updatedAt: DateTime!
  createdAt: DateTime! @createdAt
  updatedAt: DateTime! @updatedAt
}