
enum Platform {
  IOS
  ANDROID
}

enum AccountType {
  MEMBER
  ADMIN
}

type File {
  id: ID! @unique
  filename: String!
  mimetype: String!
  encoding: String!
  url: String! @unique  
  createdAt: DateTime!
}

type Video {
  id: ID! @unique
  file: File!
  createdAt: DateTime!
}

type Job {
  id: ID! @unique
  name: String! @unique
  createdAt: DateTime!
}

type User {
  id: ID! @unique
  email: String! @unique
  password: String!
  full_name: String!
  job: Job!
  role: AccountType!
  profile_photo: File
  apps: [App!]!
  libraries: [Library!]!
  createdAt: DateTime!
}

type AppVersion {
  id: ID! @unique
  name: String! @unique
  createdAt: DateTime!
}

type AppCategory {
  id: ID! @unique
  name: String! @unique
  createdAt: DateTime!
}

type StoryCategory {
  id: ID! @unique
  name: String! @unique
  createdAt: DateTime!
}

type StoryElement {
  id: ID! @unique
  name: String! @unique
  createdAt: DateTime!
}

type App {
  id: ID! @unique
  createdBy: User!
  appCategory: AppCategory!
  appVersions: [AppVersion!]!
  stories: [Story!]!
  name: String!
  description: String
  company: String!
  logo: File!
  platform: Platform!
  createdAt: DateTime!
}

type Story {
  id: ID! @unique
  createdBy: User!
  app: App!
  appVersions: [AppVersion!]!
  storyCategories: [StoryCategory!]!
  storyElements: [StoryElement!]!
  libraries: [Library!]!
  video: Video!
  thumbnail: File!
  createdAt: DateTime!
}

type Library {
  id: ID! @unique
  createdBy: User!
  stories: [Story!]!
  name: String!
  createdAt: DateTime!
}